{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pisci",
  "version": "0.1.0",
  "identifier": "com.pisci.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pisci",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "shortcutName": "Pisci AI"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["$HOME/**", "$APPDATA/**", "$DOCUMENT/**"]
      }
    }
  }
}
